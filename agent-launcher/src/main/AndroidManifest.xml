<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- The planner calls the OpenRouter LLM API over HTTPS. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- launch_app discovers and launches arbitrary installed apps by name. On Android 11+
         this requires package-visibility access; the agent is a privileged system component. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!-- Voice input (speech-to-text) for the chat mic button. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Show the daemon's foreground-service notification on Android 13+ (runtime grant). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- The daemon runs as a `connectedDevice` foreground service. On API 34+ that
         service type requires the app to hold a connected-device-class permission.
         CHANGE_WIFI_STATE / CHANGE_NETWORK_STATE are install-time permissions, so this
         is satisfied without any runtime prompt. -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <application
        android:label="@string/app_name"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <!-- Launcher entry point: starts the daemon and shows its live status.
             The NyxAgentDaemon service + BootReceiver are merged in from the
             agent-app library manifest. -->
        <activity
            android:name=".MainActivity"
            android:launchMode="singleTop"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Receives the OAuth redirect for MCP server login (nyx://oauth/callback). -->
        <activity
            android:name=".mcp.OAuthCallbackActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="nyx" android:host="oauth" android:path="/callback" />
            </intent-filter>
        </activity>

        <!-- Runs Nyx-generated mini-apps in a WebView. -->
        <activity
            android:name=".apps.AppHostActivity"
            android:exported="false" />

    </application>

</manifest>
